% --- 8. PREMIUM PULL QUOTE STYLING ---
\renewenvironment{quote}
  {\begin{tcolorbox}[
      enhanced,
      breakable,
      frame hidden,
      sharp corners,
      boxrule=0pt,
      leftrule=6pt,                % Thick left border
      colback=lightgray!40,        % Subtle background tint
      fontupper=\large\itshape\color{charcoal}, % Bigger italicized text
      top=14pt, bottom=14pt, left=16pt, right=16pt,
      overlay={
        \draw[line width=4pt, cyberred] (frame.north east) -- (frame.south east);
        \draw[line width=4pt, cyberblue] (frame.north west) -- (frame.south
        west); 
      }
    ]
  }
  {\end{tcolorbox}}

% --- 9. PANDOC COMPATIBILITY FALLBACKS ---
\newcounter{none} 
\providecommand{\tightlist}{%
  \setlength{\itemsep}{0pt}\setlength{\parskip}{0pt}}

% --- 10. HEADER/FOOTER CONFIGURATION ---
\pagestyle{fancy}
\fancyhf{}
\rhead{\small\color{gray}{$category$}}
\lfoot{\small\color{gray}{$series$}}  
\cfoot{\thepage}
\renewcommand{\headrulewidth}{0.5pt}


