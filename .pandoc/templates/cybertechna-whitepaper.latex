\documentclass[12pt, letterpaper]{article}

% --- 1. CORE PACKAGES & LAYOUT ---
\usepackage[margin=1in]{geometry}
\usepackage{graphicx}
\usepackage{fancyhdr}
\usepackage{enumitem}
\usepackage{titlesec}
\usepackage{calc}
\usepackage{setspace}

% --- 2. TABLES & GRAPHICS ---
\usepackage{tabularx}
\usepackage{booktabs}
\usepackage{longtable}
\usepackage{array}
\usepackage{colortbl} % Required for row coloring
\usepackage{tikz}
\usetikzlibrary{calc}
\usepackage[most]{tcolorbox} % Handles advanced boxes & pull quotes cleanly

% --- 3. HEX COLOR CONFIGURATION ---
\usepackage{xcolor}
\definecolor{cyberblue}{HTML}{1055CC}  
\definecolor{cyberred}{HTML}{CC0100}   % Your brand red
\definecolor{darkblue}{HTML}{061f4f}
\definecolor{charcoal}{HTML}{333333}
\definecolor{lightgray}{HTML}{F4F6F8}
\definecolor{slate}{HTML}{010619}
\definecolor{navyblue}{HTML}{172554}

% --- 4. GLOBAL FONTS & TYPOGRAPHY ---
\usepackage{fontspec}
\setmainfont{Arial}[Scale=1.05, Ligatures=TeX]
\setsansfont{Arial}[Scale=1.05]
\usepackage{csquotes}
\setstretch{1.15}

% --- 5. REMOVE STANDARD LATEX NUMBERING ---
\setcounter{secnumdepth}{0} 

% --- 6. STYLING HEADERS ---
\titleformat{\section}
  {\sffamily\Large\bfseries\color{charcoal}\filcenter}
  {}{0em}{}
\titlespacing*{\section}{0pt}{3.5ex plus 1ex minus .2ex}{2ex plus .2ex}

\titleformat{\subsection}
  {\sffamily\large\bfseries\color{charcoal}}
  {}{0em}{}
\titlespacing*{\subsection}{0pt}{2.5ex plus 0.5ex minus .2ex}{1.5ex plus .2ex}

% --- 7. PROFESSIONAL TABLE STYLING ---
\renewcommand{\arraystretch}{1.5} % Extra breathing room for executive reading

% Style longtable captions to act as an integrated corporate banner
\usepackage{caption}
\DeclareCaptionFormat{cybertable}{%
  \parbox{\linewidth}{%
    % 1. Primary Dark Blue Title Box
    \colorbox{darkblue}{\parbox{\dimexpr\linewidth-2\fboxsep\relax}{\centering\color{white}\bfseries\large #3}}\par
    \vspace{-1pt}% Snap the accent bar directly against the box above
    % 2. Split Brand Accent Bar (Left 50% Blue, Right 50% Red)
    \begin{tikzpicture}[x=1in, y=1in, line width=3pt]
      \draw[cyberblue] (0,0) -- (0.5\linewidth,0);
      \draw[cyberred] (0.5\linewidth,0) -- (\linewidth,0);
    \end{tikzpicture}
  }%
}
\captionsetup[longtable]{format=cybertable, labelformat=empty, skip=0pt, position=top}

\AtBeginDocument{
  \let\oldlongtable\longtable
  \renewcommand{\longtable}{
    \color{charcoal}\small
    \oldlongtable
  }
  % Alternating light gray zebra-striping layout
  \rowcolors{1}{lightgray!40}{white}
}

\renewcommand{\heavyrulewidth}{1.5pt}
\renewcommand{\lightrulewidth}{0.5pt}

